# HyperCycle Node Configuration
VITE_NODE_URL=http://your-node-ip:8080
VITE_AIM_PATH=/aim/image-gen/generate

# Treasury wallet (receives USDC payments on Base)
VITE_TREASURY_ADDRESS=0xYourTreasuryWalletAddress

# Optional: override payment amount (default: 1 USDC = 1000000)
VITE_PAYMENT_AMOUNT_USDC=1000000
